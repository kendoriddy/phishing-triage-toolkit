VT_API_KEY=your_virustotal_api_key_here

# Web UI
FLASK_SECRET_KEY=change-this-to-a-random-secret
FLASK_HOST=0.0.0.0
FLASK_PORT=8080
MAX_UPLOAD_MB=10

# Auth (required for public hosting)
WEB_AUTH_USERNAME=admin
WEB_AUTH_PASSWORD=your-strong-password
# Or use a hash instead of plain password:
# WEB_AUTH_PASSWORD_HASH=scrypt:...
# Optional API key for /api/analyze (Authorization: Bearer <key>)
WEB_API_KEY=

# WHOIS domain age thresholds (days)
DOMAIN_AGE_SUSPICIOUS_DAYS=30
DOMAIN_AGE_CRITICAL_DAYS=7

# VirusTotal URL poll wait (seconds). Vercel uses 8 by default.
VT_URL_POLL_SECONDS=8
