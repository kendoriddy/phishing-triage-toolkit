VT_API_KEY=your_virustotal_api_key_here

# Web UI
FLASK_SECRET_KEY=change-this-to-a-random-secret
FLASK_HOST=0.0.0.0
FLASK_PORT=8080
MAX_UPLOAD_MB=10

# Auth (opt-in — off by default for portfolio demos)
# Set ENABLE_AUTH=true to require login on the live site
ENABLE_AUTH=false
WEB_AUTH_USERNAME=admin
WEB_AUTH_PASSWORD=your-strong-password
# Or use a hash instead of plain password:
# WEB_AUTH_PASSWORD_HASH=scrypt:...
# Optional API key for /api/analyze when auth is enabled (Authorization: Bearer <key>)
WEB_API_KEY=

# Team registration (only applies when ENABLE_AUTH=true)
ALLOW_REGISTRATION=false
REGISTRATION_INVITE_CODE=your-secret-invite-code

# WHOIS domain age thresholds (days)
DOMAIN_AGE_SUSPICIOUS_DAYS=30
DOMAIN_AGE_CRITICAL_DAYS=7

# VirusTotal URL poll wait (seconds). Vercel uses 8 by default.
VT_URL_POLL_SECONDS=8
